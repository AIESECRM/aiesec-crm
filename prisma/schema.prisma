// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   // e.g. "MCP", "MCVP", "LCP", "LCVP", "TeamLeader", "TeamMember"
  avatar    String?
  branchId  String?
  teamId    String?
  createdAt DateTime @default(now())
  
  // Relations
  managedCompanies Company[] @relation("CompanyManagers")
  activities       Activity[] @relation("UserActivities")
}

model Company {
  id              String   @id @default(uuid())
  name            String
  category        String
  location        String
  phone           String
  email           String
  website         String?
  domain          String?
  taxId           String?
  status          String   // e.g. "aktif", "pasif", "negatif", "pozitif", "cevap_yok", "tekrar_ara", "toplanti_planlandi"
  activeProposals Int      @default(0)
  contactCount    Int      @default(0)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Many-to-Many relation with Users acting as Managers
  managers        User[]   @relation("CompanyManagers")
  
  // Relations
  contacts        Contact[]
  activities      Activity[]
  proposals       Proposal[]
}

model Contact {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  position  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities Activity[] // optional association
  proposals  Proposal[] // optional association
}

model Activity {
  id          String   @id @default(uuid())
  companyId   String
  contactId   String?
  userId      String
  userName    String   // Stored explicitly per the UI pattern, though can be fetched mostly from the User relation
  type        String   // e.g. "cold_call", "meeting", "email", "task", "proposal", "postponed"
  status      String   // e.g. "completed", "pending", "overdue", "cancelled"
  notes       String?  @db.Text
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  // JSON column for comments (supported by SQL Server loosely via strings or specific types, we'll map as string or simple relation)
  // To keep it clean and normalized for SQL Server:
  comments    ActivityComment[]

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user        User     @relation("UserActivities", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ActivityComment {
  id         String   @id @default(uuid())
  activityId String
  text       String   @db.Text
  author     String
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Proposal {
  id             String   @id @default(uuid())
  companyId      String
  contactId      String?
  title          String
  value          Float
  currency       String
  stage          String   // e.g. "new_lead", "qualified", "proposal", "negotiation", "closed_won", "closed_lost"
  probability    Int
  ownerId        String
  ownerName      String
  nextAction     String?
  nextActionDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   // e.g. "info", "warning", "success", "error"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model HandoverHistory {
  id          String   @id @default(uuid())
  fromUserId  String
  toUserId    String
  reason      String?  @db.Text
  timestamp   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  userId      String
  actionType  String
  entityId    String
  oldVal      String?  @db.Text
  newVal      String?  @db.Text
  ipAddress   String?
}
