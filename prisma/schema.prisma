// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// SQL Server doesn't support enums. Using String + @default instead.

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String?
  role      String    // e.g. "MCP", "MCVP", "LCP", "LCVP", "TL", "TM", "ADMIN"
  avatar    String?
  branchId  String?
  chapter   String?
  status    String    @default("ACTIVE") // e.g. "PENDING", "ACTIVE", "REJECTED"
  teamId    String?
  createdAt DateTime  @default(now())

  // Relations
  managedCompanies Company[]  @relation("CompanyManagers")
  activities       Activity[] @relation("UserActivities")
  createdCompanies Company[]  @relation("CompanyCreator")
  offers           Offer[]    @relation("OfferCreator")
}

model Company {
  id              String   @id @default(uuid())
  name            String
  category        String?
  location        String?
  phone           String?
  email           String?
  website         String?
  domain          String?
  taxId           String?
  logoUrl         String?
  chapter         String?
  status          String   @default("NO_ANSWER")
  activeProposals Int      @default(0)
  contactCount    Int      @default(0)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?

  // Many-to-Many relation with Users acting as Managers
  managers User[] @relation("CompanyManagers")

  // Relations
  creator    User?      @relation("CompanyCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contacts   Contact[]
  activities Activity[]
  proposals  Proposal[]
  offers     Offer[]
}

model Contact {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  position  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities Activity[]
  proposals  Proposal[]
  offers     Offer[]
}

model Activity {
  id          String   @id @default(uuid())
  companyId   String
  contactId   String?
  userId      String
  type        String   // e.g. "COLD_CALL", "MEETING", "EMAIL", "TASK", "PROPOSAL", "POSTPONED", "FOLLOW_UP"
  status      String   @default("pending")
  notes       String?  @db.Text
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  comments ActivityComment[]

  // Relations
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user    User     @relation("UserActivities", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ActivityComment {
  id         String   @id @default(uuid())
  activityId String
  text       String   @db.Text
  author     String
  createdAt  DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Offer {
  id          String   @id @default(uuid())
  title       String
  product     String   // "GTA", "GV", "GTE"
  duration    String   // "SHORT", "MEDIUM", "LONG"
  openStatus  String   // "NEW_OPEN", "RE_OPEN"
  value       Float?
  fileUrl     String?
  companyId   String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contactId   String?

  // Relations
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator User     @relation("OfferCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Proposal {
  id             String    @id @default(uuid())
  companyId      String
  contactId      String?
  title          String
  value          Float
  currency       String
  stage          String
  probability    Int
  ownerId        String
  ownerName      String
  nextAction     String?
  nextActionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model HandoverHistory {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  reason     String?  @db.Text
  timestamp  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  userId     String
  actionType String
  entityId   String
  oldVal     String?  @db.Text
  newVal     String?  @db.Text
  ipAddress  String?
}
