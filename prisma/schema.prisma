generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  TM
  TL
  LCVP
  LCP
  MCVP
  MCP
  ADMIN
}

enum Chapter {
  ADANA
  ANKARA
  ANTALYA
  BURSA
  DENIZLI
  DOGU_AKDENIZ
  ESKISEHIR
  GAZIANTEP
  ISTANBUL
  ISTANBUL_ASYA
  BATI_ISTANBUL
  IZMIR
  KOCAELI
  KONYA
  KUTAHYA
  SAKARYA
  TRABZON
}

enum CompanyStatus {
  POSITIVE
  NEGATIVE
  NO_ANSWER
  CALL_AGAIN
  MEETING_PLANNED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum OfferProduct {
  GTA
  GV
  GTE
}

enum OfferDuration {
  SHORT
  MEDIUM
  LONG
}

enum OfferOpenStatus {
  NEW_OPEN
  RE_OPEN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum ActivityType {
  COLD_CALL
  MEETING
  EMAIL
  FOLLOW_UP
}

model User {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(191)
  email      String     @unique @db.VarChar(191)
  password   String     @db.VarChar(191)
  role       Role       @default(TM)
  chapter    Chapter?
  status     UserStatus @default(PENDING)
  createdAt  Int        @default(0)
  updatedAt  Int        @default(0)

  companies  Company[]
  activities Activity[]
  offers     Offer[]
}

model Company {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(191)
  phone       String?       @db.VarChar(50)
  email       String?       @db.VarChar(191)
  status      CompanyStatus @default(NO_ANSWER)
  notes       String?       @db.Text
  logoUrl     String?       @db.VarChar(191)
  chapter     Chapter?
  createdAt   Int           @default(0)
  updatedAt   Int           @default(0)

  createdBy   User          @relation(fields: [createdById], references: [id])
  createdById Int

  contacts    Contact[]
  activities  Activity[]
  offers      Offer[]
}

model Contact {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(191)
  email     String? @db.VarChar(191)
  phone     String? @db.VarChar(50)
  createdAt Int     @default(0)

  company   Company @relation(fields: [companyId], references: [id])
  companyId Int
}

model Offer {
  id          Int             @id @default(autoincrement())
  title       String          @db.VarChar(191)
  product     OfferProduct
  duration    OfferDuration
  openStatus  OfferOpenStatus @default(NEW_OPEN)
  value       Float?
  fileUrl     String?         @db.VarChar(191)
  createdAt   Int             @default(0)
  updatedAt   Int             @default(0)

  company     Company         @relation(fields: [companyId], references: [id])
  companyId   Int

  createdBy   User            @relation(fields: [createdById], references: [id])
  createdById Int
}

model Activity {
  id        Int          @id @default(autoincrement())
  type      ActivityType
  note      String?      @db.Text
  date      Int          @default(0)
  createdAt Int          @default(0)

  user      User         @relation(fields: [userId], references: [id])
  userId    Int

  company   Company      @relation(fields: [companyId], references: [id])
  companyId Int
}