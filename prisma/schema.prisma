// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  TM
  TL
  LCVP
  LCP
  MCVP
  MCP
  ADMIN
}

enum Chapter {
  ADANA
  ANKARA
  ANTALYA
  BURSA
  DENIZLI
  DOGU_AKDENIZ
  ESKISEHIR
  GAZIANTEP
  ISTANBUL
  ISTANBUL_ASYA
  BATI_ISTANBUL
  IZMIR
  KOCAELI
  KONYA
  KUTAHYA
  SAKARYA
  TRABZON
}

enum CompanyStatus {
  POSITIVE
  NEGATIVE
  NO_ANSWER
  CALL_AGAIN
  MEETING_PLANNED
  ACTIVE
  PASSIVE
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum OfferProduct {
  GTA
  GV
  GTE
}

enum OfferDuration {
  SHORT
  MEDIUM
  LONG
}

enum OfferOpenStatus {
  NEW_OPEN
  RE_OPEN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum ActivityType {
  COLD_CALL
  MEETING
  EMAIL
  FOLLOW_UP
  TASK
  PROPOSAL
  POSTPONED
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String?
  role      String     // e.g. "MCP", "MCVP", "LCP", "LCVP", "TL", "TM", "ADMIN"
  avatar    String?
  branchId  String?
  chapter   String?
  status    String     @default("ACTIVE")
  teamId    String?
  createdAt DateTime   @default(now())

  // Relations
  managedCompanies Company[]  @relation("CompanyManagers")
  activities       Activity[] @relation("UserActivities")
}

model Company {
  id              String        @id @default(uuid())
  name            String
  category        String?
  location        String?
  phone           String?
  email           String?
  website         String?
  domain          String?
  taxId           String?
  logoUrl         String?
  chapter         String?
  status          String        @default("NO_ANSWER")
  activeProposals Int           @default(0)
  contactCount    Int           @default(0)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Many-to-Many relation with Users acting as Managers
  managers        User[]        @relation("CompanyManagers")

  // Relations
  contacts        Contact[]
  activities      Activity[]
  proposals       Proposal[]
}

model Contact {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  position  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities Activity[] // optional association
  proposals  Proposal[] // optional association
}

model Activity {
  id          String    @id @default(uuid())
  companyId   String
  contactId   String?
  userId      String
  userName    String
  type        String    // e.g. "COLD_CALL", "MEETING", "EMAIL", "TASK", "PROPOSAL", "POSTPONED", "FOLLOW_UP"
  status      String    @default("pending") // e.g. "completed", "pending", "overdue", "cancelled"
  notes       String?   @db.Text
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  comments    ActivityComment[]

  // Relations
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user        User      @relation("UserActivities", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ActivityComment {
  id         String   @id @default(uuid())
  activityId String
  text       String   @db.Text
  author     String
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model Proposal {
  id             String    @id @default(uuid())
  companyId      String
  contactId      String?
  title          String
  value          Float
  currency       String
  stage          String    // e.g. "new_lead", "qualified", "proposal", "negotiation", "closed_won", "closed_lost"
  probability    Int
  ownerId        String
  ownerName      String
  nextAction     String?
  nextActionDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact?  @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   // e.g. "info", "warning", "success", "error"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model HandoverHistory {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  reason     String?  @db.Text
  timestamp  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  userId     String
  actionType String
  entityId   String
  oldVal     String?  @db.Text
  newVal     String?  @db.Text
  ipAddress  String?
}
